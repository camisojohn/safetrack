<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:alpha="0.7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/imgArchivedIncident"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvArchivedType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="#888888"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvArchivedTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A2940"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvArchivedReporter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDeletedAt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#F44336"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnPermanentDelete"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Permanently Delete"
                android:textSize="13sp"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
